import java.util.*;
public class math{
    public static void main(String args[]){
        int x,y;
        Scanner sc=new Scanner(System.in);
        x=sc.nextInt();
        y=sc.nextInt();
        int a=(x+y);
        int b=(x-y);
        int c=(x*y);
        int d=(x/y);
        System.out.println(a);
        System.out.println(b);
        System.out.println(c);
        System.out.println(d);   
    }  
}
